# Free LLM — pick ONE (Groq recommended, no credit card)
GROQ_API_KEY=gsk_your_key_here

# Or use OpenRouter ($10 hackathon credit)
# OPENROUTER_API_KEY=sk-or-your_key_here

# Optional: raises GitHub API from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_your_token_here

# Set automatically by `npx convex dev`
VITE_CONVEX_URL=

# Email reports via Resend (free: resend.com)
# Set in Convex dashboard too: npx convex env set RESEND_API_KEY re_xxx
RESEND_API_KEY=
